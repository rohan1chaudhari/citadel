# Citadel Environment Configuration
# Copy this file to .env and fill in your values, or set in your shell.

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Server port (default: 3000)
# CITADEL_PORT=3000

# Data directory path (default: ../data)
# CITADEL_DATA_ROOT=./data

# Apps directory path (default: ../apps)
# CITADEL_APPS_DIR=./apps

# Repository root path (auto-detected if not set)
# CITADEL_REPO_ROOT=

# =============================================================================
# BACKUP SETTINGS
# =============================================================================

# Number of backups to retain (default: 7)
# CITADEL_BACKUP_RETENTION=7

# Hours between automatic backups (default: 24)
# CITADEL_BACKUP_INTERVAL_HOURS=24

# =============================================================================
# FIRST-RUN SETTINGS
# =============================================================================

# Skip the first-run setup wizard (default: false)
# Set to true for Docker/automated deployments
# CITADEL_SKIP_SETUP=false

# =============================================================================
# LLM PROVIDER KEYS (Required for AI features)
# =============================================================================

# OpenAI API key (for GPT models, vision, transcription)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key (for Claude models, Claude Code runner)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OPTIONAL FEATURE KEYS
# =============================================================================

# ElevenLabs API key (for voice/text-to-speech features)
# ELEVENLABS_API_KEY=eleven-xxxxxxxx

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Node environment (development/production)
# NODE_ENV=production
